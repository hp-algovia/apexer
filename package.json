{
  "name": "apexer",
  "private": true,
  "version": "0.1.0",
  "description": "APEXER — infrastructure nationale française pour la performance commerciale durable",
  "packageManager": "pnpm@11.0.5",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "eslint": "8.57.0",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.8",
    "turbo": "2.1.3",
    "typescript": "5.5.4"
  },
  "lint-staged": {
    "apps/*/**/*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "packages/*/**/*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
